pkgbase = omnideck
	pkgdesc = 10-foot, controller-first media & game launcher for Linux
	pkgver = 0.1.0
	pkgrel = 1
	url = https://github.com/atiner117/omnideck
	install = omnideck.install
	arch = x86_64
	license = GPL-3.0-or-later
	makedepends = rust
	makedepends = cargo
	makedepends = bun-bin
	makedepends = pkgconf
