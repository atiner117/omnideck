	optdepends = gamescope: 10-foot gamescope session mode (run packaging/install-session.sh)
	optdepends = steam: Steam library scanning + launching
	optdepends = playerctl: live song/show titles in Now Playing (MPRIS)
	optdepends = xorg-xprop: STEAM_GAME atom handling inside the gamescope session
	optdepends = cage: media-kiosk tier on hosts without a usable GPU
	options = !lto
